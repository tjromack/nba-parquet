# Copy to infra/airflow.env (gitignored) and edit as needed.
#
# These vars are read by every Airflow container in docker-compose.yml.
# Don't commit secrets here — use the project root .env for AWS keys.

# --- Airflow core ---
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
# Generate a real key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-in-prod
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth,airflow.api.auth.backend.session
AIRFLOW__SCHEDULER__MIN_FILE_PROCESS_INTERVAL=30

# --- NBA ETL pipeline ---
# Mirror the project root .env. LOCAL_OUTPUT_DIR points at the volume
# mounted from the host's ./out/.
LOCAL_OUTPUT_DIR=/opt/airflow/out
S3_BUCKET=
NBA_SEASON=2025-26
NBA_SEASON_TYPE=Playoffs

# --- AWS (only needed when S3_BUCKET is the destination) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=
