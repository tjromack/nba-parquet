# --- Output destination ---
# Set EITHER S3_BUCKET (S3 / LocalStack) OR LOCAL_OUTPUT_DIR (smoke test, no S3 at all).
# If LOCAL_OUTPUT_DIR is set, it wins and S3 config is ignored.
S3_BUCKET=your-nba-etl-bucket
LOCAL_OUTPUT_DIR=

# --- AWS (only needed when S3_BUCKET is the destination) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=

NBA_SEASON=2025-26
NBA_INGEST_DATE=
NBA_SEASON_TYPE=Playoffs

# --- Airflow stack (used by infra/docker-compose.yml) ---
# UID inside the airflow container; on Windows + Docker Desktop, keeping
# the default 50000 works fine. On Linux, set to your host UID
# (`id -u`) to avoid permission issues on the mounted ./out/ directory.
AIRFLOW_UID=50000
# The Airflow stack reads its own env vars from infra/airflow.env (gitignored,
# templated by infra/airflow.env.example). The two lines below are kept for
# legacy reference only — they are NOT consumed by the local pipeline.
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
